# Copy to .env (gitignored). PUBLIC_ prefix is required for vars that
# need to be visible in the client-side bundle (canonical URLs, CDN base).

PUBLIC_SITE_URL=

# Cloudflare R2 custom domain for image assets.
PUBLIC_CDN_URL=

# RoofKit. Swap landing-slug to point at a different dashboard template.
PUBLIC_ROOFKIT_ROOFER_ID=
PUBLIC_ROOFKIT_LANDING_SLUG=
PUBLIC_ROOFKIT_WIDGET_SRC=https://roofkit.ai/roofkit-embed.js

# R2 credentials (consumed by scripts/upload-images-to-r2.mjs only; NOT
# exposed to the client bundle since they do not have the PUBLIC_ prefix).

R2_API_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# S3-compatible endpoint for the R2 bucket
S3_API_URL=
