---
import VisualizerButton from '@components/visualizer/VisualizerButton.astro';
import { imageSrc } from '@lib/cdn';

interface Props {
  data: {
    kicker: string;
    title_html: string;
    body: string;
    cta_label: string;
    preview_image_local_path: string | null;
    preview_image_cdn_url: string | null;
    badge_text?: string;
    visualizer_payload: Record<string, unknown>;
  };
  /** The SKU's primary hex for the badge dot accent. */
  skuHex?: string;
}
const { data, skuHex = '#4A536A' } = Astro.props;
const previewUrl = imageSrc({
  image_local_path: data.preview_image_local_path,
  image_cdn_url: data.preview_image_cdn_url,
});
---
<section class="try-it on-dark" style={`--sku-color:${skuHex}`}>
  <div class="wrap try-it-inner">
    <div class="try-copy">
      <span class="kicker">{data.kicker}</span>
      <div class="title" set:html={data.title_html}></div>
      <p>{data.body}</p>
      <VisualizerButton payload={data.visualizer_payload} label={data.cta_label} variant="launch" />
    </div>

    <button type="button" class="try-launcher" data-visualizer={JSON.stringify(data.visualizer_payload)}>
      <div class="preview">
        {previewUrl && <img src={previewUrl} alt="Visualizer preview" loading="lazy" />}
        {data.badge_text && (
          <div class="badge">
            <span class="dot" aria-hidden="true"></span>
            <span>{data.badge_text}</span>
          </div>
        )}
      </div>
      <div class="action-row">
        <div class="action-title">Tap to open the visualizer</div>
        <div class="arrow" aria-hidden="true">→</div>
      </div>
    </button>
  </div>
</section>

<style>
  .try-it {
    padding: 100px 0;
    background: var(--ink);
    color: var(--paper);
  }
  @media (max-width: 720px) { .try-it { padding: 60px 0; } }

  .try-it-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 880px) {
    .try-it-inner { grid-template-columns: 1fr; gap: 36px; }
  }

  .try-copy .kicker {
    color: rgba(242, 236, 222, 0.55);
    display: inline-block;
    margin-bottom: 14px;
  }
  .try-copy .title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5.4vw, 72px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin: 0 0 22px;
  }
  .try-copy .title :global(em) { font-style: italic; color: var(--clay); }
  .try-copy p {
    color: rgba(242, 236, 222, 0.7);
    font-size: 16px;
    line-height: 1.55;
    max-width: 44ch;
    margin: 0 0 28px;
  }

  .try-launcher {
    background: rgba(242, 236, 222, 0.06);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(242, 236, 222, 0.18);
    border-radius: 18px;
    padding: 28px;
    cursor: pointer;
    transition: background var(--t-med) var(--ease),
                 border-color var(--t-med) var(--ease),
                 transform var(--t-fast) var(--ease);
    width: 100%;
    text-align: left;
  }
  .try-launcher:hover {
    background: rgba(242, 236, 222, 0.12);
    border-color: rgba(242, 236, 222, 0.32);
    transform: translateY(-2px);
  }
  .try-launcher .preview {
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    margin-bottom: 22px;
    background: var(--sku-color);
  }
  .try-launcher .preview img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .try-launcher .badge {
    position: absolute;
    top: 14px; left: 14px;
    background: rgba(26, 34, 54, 0.85);
    padding: 6px 10px 6px 6px;
    border-radius: 999px;
    display: flex; align-items: center; gap: 8px;
    z-index: 2;
  }
  .try-launcher .badge .dot {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--sku-color);
    border: 2px solid rgba(242, 236, 222, 0.55);
  }
  .try-launcher .badge span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
  }
  .try-launcher .action-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .try-launcher .action-title {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--paper);
    line-height: 1.2;
    max-width: 16ch;
  }
  .try-launcher .arrow {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--clay);
    color: var(--paper);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    flex-shrink: 0;
    transition: transform var(--t-fast) var(--ease),
                 background var(--t-fast) var(--ease);
  }
  .try-launcher:hover .arrow {
    transform: translateX(4px);
    background: var(--clay-deep);
  }
</style>
