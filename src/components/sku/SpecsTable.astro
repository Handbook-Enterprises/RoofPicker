---
interface Props {
  data: {
    kicker: string;
    title_html: string;
    rows: Array<{ cat: string; val: string; ctx: string }>;
    docs: Array<{ label: string; url: string; type: string }>;
    sources?: Array<{ label: string; url: string }>;
  };
}
const { data } = Astro.props;

// Humanize raw scraped filenames into homeowner-readable doc labels.
function prettyDocLabel(raw: string, url?: string): string {
  let s = (raw ?? '').trim();
  if (!s && url) {
    try {
      const u = new URL(url);
      s = u.pathname.split('/').pop() ?? '';
    } catch { /* not a URL */ }
  }
  try { s = decodeURIComponent(s); } catch { /* malformed % escape */ }
  s = s.replace(/\.(pdf|docx?|xlsx?)$/i, '');
  // Strip FBC prefix tokens (FL<n> R<n> AE <vendor-id>); keep the descriptive tail.
  s = s.replace(/^FL\d+\s+R\d+\s+AE\s+\S+\s+/i, '');
  s = s.replace(/[_\-]+/g, ' ').replace(/\s+/g, ' ').trim();
  if (/\bFBC\b/i.test(s)) s = s.replace(/\bFBC\b/g, 'Florida Building Code');
  if (/\bEval\b/i.test(s)) s = s.replace(/\bEval\b/gi, 'Evaluation');
  // Title-case if it's still all-lowercase or all-uppercase
  if (s === s.toLowerCase() || s === s.toUpperCase()) {
    s = s.toLowerCase().replace(/\b([a-z])/g, (_, c) => c.toUpperCase());
  }
  // Drop trailing "final" / "draft" markers (internal versioning noise).
  s = s.replace(/\s+\b(final|draft|v\d+(\.\d+)*)\b\s*$/i, '');
  return s.trim() || 'Product document';
}
---
<section class="specs">
  <div class="wrap">
    <div class="specs-head">
      <span class="kicker">{data.kicker}</span>
      <div class="title" set:html={data.title_html}></div>
    </div>

    <table class="specs-table">
      <caption class="visually-hidden">Product specifications</caption>
      <tbody>
        {data.rows.map((row) => (
          <tr>
            <td class="cat">{row.cat}</td>
            <td class="val">
              {row.val}
              <div class="ctx">{row.ctx}</div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    {data.docs && data.docs.length > 0 && (
      <div class="specs-docs" aria-label="Product documents">
        {data.docs.map((d) => (
          <a class="doc-pill" href={d.url} target="_blank" rel="noopener noreferrer external">
            <span class="pdf-tag">PDF</span>
            <span>{prettyDocLabel(d.label, d.url)}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .specs {
    background: var(--ink);
    color: var(--paper);
    padding: 100px 0;
  }
  @media (max-width: 720px) { .specs { padding: 60px 0; } }

  .specs-head {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 40px;
    margin-bottom: 48px;
    align-items: baseline;
  }
  @media (max-width: 760px) {
    .specs-head { grid-template-columns: 1fr; gap: 16px; margin-bottom: 28px; }
  }
  .specs-head .kicker { color: rgba(242, 236, 222, 0.55); }
  .specs-head .title {
    font-family: var(--font-serif);
    font-size: clamp(34px, 4.8vw, 66px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: var(--paper);
  }
  .specs-head .title :global(em) { font-style: italic; color: var(--clay); }

  .specs-table {
    width: 100%;
    border-collapse: collapse;
  }
  .specs-table tr { border-bottom: 1px solid rgba(242, 236, 222, 0.18); }
  .specs-table tr:first-child { border-top: 1px solid rgba(242, 236, 222, 0.18); }
  .specs-table td {
    padding: 22px 16px;
    vertical-align: top;
  }
  .specs-table .cat {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(242, 236, 222, 0.55);
    width: 32%;
  }
  .specs-table .val {
    font-family: var(--font-serif);
    font-size: 24px;
    line-height: 1.2;
    color: var(--paper);
    letter-spacing: -0.005em;
  }
  .specs-table .val :global(em) { font-style: italic; color: var(--clay); }
  .specs-table .ctx {
    margin-top: 4px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: rgba(242, 236, 222, 0.6);
    line-height: 1.4;
  }
  @media (max-width: 720px) {
    .specs-table td { display: block; padding: 4px 0; }
    .specs-table tr { padding: 18px 0; }
    .specs-table .cat { width: 100%; margin-bottom: 8px; }
  }

  .specs-docs {
    margin-top: 36px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .doc-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(242, 236, 222, 0.08);
    border: 1px solid rgba(242, 236, 222, 0.2);
    color: var(--paper);
    padding: 12px 18px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background var(--t-fast) var(--ease),
                 border-color var(--t-fast) var(--ease);
  }
  .doc-pill:hover {
    background: rgba(242, 236, 222, 0.16);
    border-color: rgba(242, 236, 222, 0.4);
  }
  .pdf-tag {
    background: var(--clay);
    color: var(--paper);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 9px;
    letter-spacing: 0.1em;
  }
</style>
