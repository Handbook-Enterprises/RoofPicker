---
// Strategy 6 per-color hub page.
// CSS verbatim from Color-Gallery-Hub-Template; refresh: npm run port-color-hub.
import { imageSrc, safeAlt } from '@lib/cdn';
import colorHubCss from '@styles/color-hub.css?raw';
import { fixBreadcrumb } from '@lib/breadcrumb';

interface Props {
  data: Record<string, any>;
}
const { data } = Astro.props;

// --- Hero ------------------------------------------------------------
const hero = data.hub_hero ?? {};
const heroMosaic: Array<any> = Array.isArray(hero.hero_mosaic) ? hero.hero_mosaic.slice(0, 12) : [];
const stats: Array<{ num: number | string; label: string }> = Array.isArray(hero.stats) ? hero.stats : [];
// Rewrite hrefs to existing parents. See lib/breadcrumb.ts.
const breadcrumb: Array<{ label: string; url: string | null }> =
  fixBreadcrumb(Array.isArray(hero.breadcrumb) ? hero.breadcrumb : []);

// --- Combos table ---------------------------------------------------
const combos = data.combos ?? {};
const sidingChips: Array<any> = Array.isArray(combos.siding_chips) ? combos.siding_chips : [];
const styleTags: Array<any> = Array.isArray(combos.style_tags) ? combos.style_tags : [];

// --- Visualizer CTA --------------------------------------------------
const vcta = data.visualizer_cta ?? {};
const vctaPayload = vcta.visualizer_payload ?? {};
const vctaPreview = imageSrc({
  image_local_path: vcta.preview_image_local_path,
  image_cdn_url:    vcta.preview_image_cdn_url,
});

// --- Long gallery ---------------------------------------------------
const galleryGroups: Array<any> = Array.isArray(data.long_gallery?.groups)
  ? data.long_gallery.groups : [];

// --- Materials -------------------------------------------------------
const materialCards: Array<any> = Array.isArray(data.materials?.cards) ? data.materials.cards : [];

// --- Crosslinks ------------------------------------------------------
const crossColumns: Array<any> = Array.isArray(data.crosslinks?.columns) ? data.crosslinks.columns : [];

// --- FAQ -------------------------------------------------------------
const faqs: Array<{ q: string; a: string }> = Array.isArray(data.faq_items) ? data.faq_items : [];

// --- Closing ---------------------------------------------------------
const closing = data.closing ?? {};
const closingPayload = closing.visualizer_payload ?? {};

const vctaPayloadJson = JSON.stringify(vctaPayload);
const closingPayloadJson = JSON.stringify(closingPayload);

const roofArchetypeDisplay = (data.roof_archetype_display ?? 'roof').toLowerCase();
---
<style is:global set:html={colorHubCss}></style>

<section class="hub-hero">
  <div class="wrap">
    {breadcrumb.length > 0 && (
      <nav class="breadcrumb" aria-label="Breadcrumb">
        {breadcrumb.map((c, i, arr) => (
          <>
            {c.url
              ? <a href={c.url}>{c.label}</a>
              : <span class="current">{c.label}</span>}
            {i < arr.length - 1 && <span class="sep">/</span>}
          </>
        ))}
      </nav>
    )}

    <div class="hub-title-block">
      <div>
        {hero.kicker && <span class="kicker">{hero.kicker}</span>}
        {hero.h1_html && <h1 set:html={hero.h1_html}></h1>}
      </div>

      <div class="hub-intro">
        {hero.intro && <p set:html={hero.intro}></p>}
        {stats.length > 0 && (
          <div class="stats">
            {stats.map((s, i) => (
              <div>
                <div class="stat-num">{i === 0 ? <em>{s.num}</em> : s.num}</div>
                <div class="stat-lbl">{s.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>

    {heroMosaic.length > 0 && (
      <div class="hero-mosaic">
        {heroMosaic.map((t, i) => (
          <figure class={`htile h${i + 1}`}>
            {t.sku_url
              ? <a href={t.sku_url}>
                  <img src={imageSrc(t)} alt={safeAlt(t, hero.h1_text ?? '')} loading="lazy" />
                </a>
              : <img src={imageSrc(t)} alt={safeAlt(t, hero.h1_text ?? '')} loading="lazy" />}
            {t.tag && <div class="tag">{t.tag}</div>}
          </figure>
        ))}
      </div>
    )}
  </div>
</section>

{(sidingChips.length > 0 || styleTags.length > 0) && (
  <section class="combos">
    <div class="wrap">
      <div class="combos-head">
        <div>
          {combos.kicker && <span class="kicker">{combos.kicker}</span>}
          {combos.title_html && <div class="title" set:html={combos.title_html}></div>}
        </div>
        {combos.note && <div class="note">{combos.note}</div>}
      </div>

      <div class="combos-card">
        <div class="combos-row header">
          <div class="cell">Roof color</div>
          <div class="cell">Recommended siding colors</div>
          <div class="cell">House styles that fit</div>
        </div>

        <div class="combos-row">
          <div class="cell" data-label="Roof color">
            {combos.roof_pill && (
              <div class="roof-pill">
                <span class="swatch" style={`background:${combos.roof_pill.hex};`}></span>
                <span class="name">{combos.roof_pill.name}</span>
              </div>
            )}
          </div>
          <div class="cell" data-label="Siding colors">
            {sidingChips.length > 0 && (
              <div class="siding-list">
                {sidingChips.map((s) => (
                  <a class="siding-chip" href={s.combo_page_url} style={`--siding: ${s.color_hex};`}>
                    <span class="swatch"></span>{s.color_display}
                  </a>
                ))}
              </div>
            )}
          </div>
          <div class="cell" data-label="House styles">
            {styleTags.length > 0 && (
              <div class="style-list">
                {styleTags.map((s) => (
                  s.combo_page_url
                    ? <a class="style-tag" href={s.combo_page_url}>{s.style_display}</a>
                    : <span class="style-tag">{s.style_display}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<section class="visualizer-cta">
  <div class="wrap vcta-inner">
    <div class="vcta-copy">
      {vcta.kicker && <span class="kicker">{vcta.kicker}</span>}
      {vcta.title_html && <div class="title" set:html={vcta.title_html}></div>}
      {vcta.body && <p>{vcta.body}</p>}
      <button class="btn-launch" data-launch={vctaPayloadJson}>
        {vcta.cta_label ?? 'Open visualizer'} <span class="arrow">→</span>
      </button>
    </div>

    <button class="vcta-launcher" data-launch={vctaPayloadJson}>
      <div class="preview">
        {vctaPreview && <img src={vctaPreview} alt={vcta.filter_badge?.label ?? ''} />}
        {vcta.filter_badge && (
          <div class="filter-badge">
            {vcta.filter_badge.swatch_hex && (
              <span class="swatch" style={`background:${vcta.filter_badge.swatch_hex};`}></span>
            )}
            <span class="label">{vcta.filter_badge.label}</span>
          </div>
        )}
      </div>
      <div class="action-row">
        <div class="action-title">Tap to open visualizer</div>
        <div class="arrow-btn">→</div>
      </div>
    </button>
  </div>
</section>

{galleryGroups.length > 0 && (
  <section class="long-gallery">
    <div class="wrap">
      {data.long_gallery?.title_html && (
        <div class="long-gallery-head">
          <div class="title" set:html={data.long_gallery.title_html}></div>
        </div>
      )}
      {galleryGroups.map((group) => (
        <div class="ssection">
          <div class="ssection-head">
            {group.title_html && <div class="title" set:html={group.title_html}></div>}
            <div class="meta">
              {group.count !== undefined && <span class="count">{group.count} examples</span>}
              {group.see_all_url && (
                <a href={group.see_all_url} class="see-all">
                  See all {group.title_text ? group.title_text.toLowerCase() : ''} →
                </a>
              )}
            </div>
          </div>
          {Array.isArray(group.tiles) && group.tiles.length > 0 && (
            <div class="ssection-grid">
              {group.tiles.slice(0, 6).map((t: any, i: number) => (
                <figure class={`gtile x${(i % 6) + 1}`}>
                  {t.sku_url
                    ? <a href={t.sku_url}>
                        <img src={imageSrc(t)} alt={safeAlt(t, group.title_text ?? '')} loading="lazy" />
                      </a>
                    : <img src={imageSrc(t)} alt={safeAlt(t, group.title_text ?? '')} loading="lazy" />}
                  {t.tag && <div class="tag">{t.tag}</div>}
                </figure>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
)}

{materialCards.length > 0 && (
  <section class="materials">
    <div class="wrap">
      <div class="materials-head">
        {data.materials?.kicker && <span class="kicker">{data.materials.kicker}</span>}
        {data.materials?.title_html && <div class="title" set:html={data.materials.title_html}></div>}
      </div>

      <div class="materials-grid">
        {materialCards.map((card) => (
          <a href={card.url} class="material-card" style={`--material-bg: ${card.card_bg_hex};`}>
            <div class="visual"></div>
            <div class="body">
              {card.kicker && <span class="kicker">{card.kicker}</span>}
              {card.h3_html && <h3 set:html={card.h3_html}></h3>}
              {card.body && <p>{card.body}</p>}
              {card.arrow_link_text && <span class="arrow-link">{card.arrow_link_text} →</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{crossColumns.length > 0 && (
  <section class="crosslinks">
    <div class="wrap">
      <div class="crosslinks-head">
        {data.crosslinks?.kicker && <span class="kicker">{data.crosslinks.kicker}</span>}
        {data.crosslinks?.title_html && <div class="title" set:html={data.crosslinks.title_html}></div>}
      </div>

      <div class="crosslinks-grid">
        {crossColumns.map((col) => (
          <div class="crosscol">
            {col.title && <h4>{col.title}</h4>}
            {Array.isArray(col.items) && col.items.length > 0 && (
              <ul>
                {col.items.map((it: any) => (
                  <li>
                    <a href={it.url}>
                      <span>
                        {it.swatch_hex && (
                          <span class="swatch-dot" style={`background:${it.swatch_hex};`}></span>
                        )}
                        {it.label}
                      </span>
                      <span class="arrow">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{faqs.length > 0 && (
  <section class="faq">
    <div class="wrap faq-inner">
      <div class="faq-head">
        <span class="kicker">Common <em>questions</em></span>
        <div class="title">About <em>{roofArchetypeDisplay} roofs</em>.</div>
        <p class="note">The questions Google's "People Also Ask" surfaces for this query, answered without sales spin.</p>
      </div>

      <div class="faq-list" id="faqList">
        {faqs.map((qa, i) => (
          <div class={i === 0 ? 'qa open' : 'qa'}>
            <button class="qa-q"><span>{qa.q}</span><span class="plus"></span></button>
            <div class="qa-a"><p>{qa.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<section class="closing">
  <div class="wrap">
    {closing.kicker && <span class="kicker">{closing.kicker}</span>}
    {closing.h2_html && <h2 set:html={closing.h2_html}></h2>}
    <button class="btn-primary" data-launch={closingPayloadJson}>
      {closing.cta_label ?? 'Open the visualizer'} <span class="arrow">→</span>
    </button>
  </div>
</section>

<script is:inline>
  // FAQ accordion — copied verbatim from the template.
  (function () {
    const list = document.getElementById('faqList');
    if (!list) return;
    list.addEventListener('click', (e) => {
      const btn = e.target.closest('.qa-q');
      if (!btn) return;
      const qa = btn.parentElement;
      const open = qa.classList.contains('open');
      list.querySelectorAll('.qa').forEach((x) => x.classList.remove('open'));
      if (!open) qa.classList.add('open');
    });
  })();

  // Visualizer launcher stub. Wires to RoofKit when available.
  function openVisualizer(payload) {
    console.log('Open visualizer:', payload);
    var filter = payload && payload.color_filter ? payload.color_filter : '';
    alert('RoofKit visualizer opens here.\n\n' +
      (filter ? 'Filter: ' + filter : 'No filter applied'));
  }
  document.querySelectorAll('[data-launch]').forEach(function (el) {
    el.addEventListener('click', function () {
      var raw = el.getAttribute('data-launch') || '{}';
      try { openVisualizer(JSON.parse(raw)); } catch (e) { openVisualizer({}); }
    });
  });
</script>
