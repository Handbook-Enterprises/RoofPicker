---
// Strategy 4 hub. Hub copy from src/data/hubs/combinations-s4.json;
// cards from the combinations-s4 collection. Design: Docs/design.md.
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { breadcrumbList } from '@lib/schema';
import hubJson from '../../data/hubs/combinations-s4.json';
import { imageSrc } from '@lib/cdn';

const hub = hubJson as Record<string, any>;

const all = await getCollection('combinations-s4');
const items = all
  .map((e) => e.data as Record<string, any>)
  .sort((a, b) => String(a.house_color_display ?? '').localeCompare(String(b.house_color_display ?? '')));
---
<BaseLayout
  title={String(hub.meta_title ?? hub.h1 ?? 'Roof color combinations')}
  description={String(hub.meta_description ?? hub.hub_intro ?? '')}
  canonical="/combinations/"
  jsonLd={[breadcrumbList([
    { label: 'Home', url: '/' },
    { label: 'Combinations', url: '/combinations/' },
  ])]}
>
  <main class="combos-hub">
    <section class="hub-hero">
      <div class="wrap">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <span class="current">Combinations</span>
        </nav>
        <span class="kicker">House color × roof color · 2026</span>
        <h1>Every house and every <em>roof</em>, side by side.</h1>
        {hub.hub_intro && <p class="lede">{String(hub.hub_intro)}</p>}
      </div>
    </section>

    <section class="hub-list-section">
      <div class="wrap">
        <span class="kicker">{items.length} pairings</span>
        <div class="combo-grid">
          {items.map((c) => {
            // S4 hero lives at combo_hero.hero_mosaic[0].
            const firstTile = Array.isArray((c as any).combo_hero?.hero_mosaic) && (c as any).combo_hero.hero_mosaic.length > 0
              ? (c as any).combo_hero.hero_mosaic[0]
              : null;
            const hero = imageSrc(firstTile)
              || imageSrc((c as any).combo_hero?.hero_image_local_path
                ? { image_local_path: (c as any).combo_hero.hero_image_local_path, image_cdn_url: (c as any).combo_hero.hero_image_cdn_url }
                : null);
            return (
              <a class="combo-card" href={String(c.url_path)}>
                <div class="card-visual">
                  {hero
                    ? <img src={hero} alt={`${c.house_color_display} house with ${c.roof_color_display} roof`} loading="lazy" />
                    : <div class="card-fallback">
                        <span class="swatch house" style={`background:${c.house_color_hex};`}></span>
                        <span class="swatch roof"  style={`background:${c.roof_color_hex};`}></span>
                      </div>
                  }
                </div>
                <div class="card-body">
                  <span class="card-kicker">Combination</span>
                  <h2><em>{c.house_color_display}</em> + {c.roof_color_display}</h2>
                  <span class="card-action">See the pair <span class="arrow">→</span></span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <section class="closing">
      <div class="wrap">
        <span class="kicker">Pick a pair</span>
        <h2>Try it on <em>your</em> house.</h2>
        <a class="btn-primary" href="/">Open the visualizer <span class="arrow">→</span></a>
      </div>
    </section>
  </main>

  <style>
    .combos-hub { padding: 0 0 120px; }

    .hub-hero { padding: 80px 0 56px; }
    .hub-hero .wrap, .hub-list-section .wrap, .closing .wrap {
      max-width: 1200px; margin: 0 auto; padding: 0 32px;
    }
    @media (max-width: 720px) {
      .hub-hero .wrap, .hub-list-section .wrap, .closing .wrap { padding: 0 20px; }
    }

    .breadcrumb {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-soft); margin-bottom: 28px;
      display: flex; align-items: center; gap: 10px;
    }
    .breadcrumb a:hover { color: var(--clay); }
    .breadcrumb .sep { opacity: 0.4; }
    .breadcrumb .current { color: var(--ink); }

    .kicker {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 11px; font-weight: 500; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--ink-soft);
      display: block; margin-bottom: 20px;
    }

    .hub-hero h1 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: clamp(48px, 8vw, 108px);
      line-height: 1.0; letter-spacing: -0.02em;
      color: var(--ink); margin: 0 0 24px; max-width: 13ch;
    }
    .hub-hero h1 em { font-style: italic; color: var(--clay); }

    .hub-hero .lede {
      font-family: "Geist", system-ui, sans-serif;
      font-size: 18px; line-height: 1.55; color: var(--ink-soft);
      max-width: 65ch; margin: 0;
    }

    .hub-list-section { padding: 40px 0 60px; }

    .combo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 24px;
    }

    .combo-card {
      display: flex; flex-direction: column;
      background: var(--shell);
      border: 1px solid var(--rule);
      border-radius: 18px;
      overflow: hidden;
      color: var(--ink);
      transition: border-color 200ms cubic-bezier(.4,0,.2,1),
                  transform 200ms cubic-bezier(.4,0,.2,1),
                  box-shadow 200ms cubic-bezier(.4,0,.2,1);
    }
    .combo-card:hover {
      border-color: var(--clay);
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(26,34,54,0.08);
    }

    .card-visual {
      aspect-ratio: 4 / 3;
      background: var(--paper);
      position: relative;
      overflow: hidden;
    }
    .card-visual img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
    }
    .card-fallback {
      position: absolute; inset: 0;
      display: flex;
    }
    .card-fallback .swatch {
      flex: 1;
      display: block;
    }
    .card-fallback .swatch.roof {
      flex: 0.6;
    }

    .card-body { padding: 22px 24px 24px; display: flex; flex-direction: column; gap: 10px; }
    .card-kicker {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ink-soft);
    }
    .combo-card h2 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: 26px; line-height: 1.1; letter-spacing: -0.01em;
      color: var(--ink); margin: 0;
    }
    .combo-card h2 em {
      font-style: italic; color: var(--clay);
    }
    .card-action {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--clay);
      display: inline-flex; align-items: center; gap: 6px;
      margin-top: 4px;
    }
    .card-action .arrow { transition: transform 200ms cubic-bezier(.4,0,.2,1); }
    .combo-card:hover .card-action .arrow { transform: translateX(4px); }

    .closing { padding: 80px 0 0; text-align: center; }
    .closing h2 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: clamp(36px, 5.4vw, 80px);
      line-height: 1.0; letter-spacing: -0.02em;
      color: var(--ink); margin: 0 0 32px;
    }
    .closing h2 em { font-style: italic; color: var(--clay); }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--clay); color: var(--paper);
      padding: 16px 26px; border-radius: 999px;
      font-family: "Geist", system-ui, sans-serif;
      font-size: 15px; font-weight: 500;
      transition: background 150ms cubic-bezier(.4,0,.2,1),
                  transform 150ms cubic-bezier(.4,0,.2,1);
    }
    .btn-primary:hover { background: var(--clay-deep); transform: translateY(-1px); }
    .btn-primary .arrow { transition: transform 150ms cubic-bezier(.4,0,.2,1); }
    .btn-primary:hover .arrow { transform: translateX(3px); }
  </style>
</BaseLayout>
