      <!-- ============================ PAGINATION ============================
        Pagination is OPTIONAL and conditional. Include this <nav> block
        ONLY when the number of grid items exceeds the page threshold
        (default: 24 per page).

        For the Master Color Index shown above (13 items), pagination is
        not needed. The block below is rendered here for demonstration
        purposes so designers and devs can see the visual pattern.

        Variants that DO need pagination:
          - "All SKUs" index (230 items)
          - GAF Timberline HDZ Line Hub (33 colors)
          - Any other hub where item count > 24
        ============================================================ -->
      <nav class="pagination" aria-label="Pagination">

        <div class="controls">
          <a href="?page=0" class="page-prev disabled" aria-disabled="true">
            <span>←</span><span>Previous</span>
          </a>

          <ol class="page-list">
            <li><a href="?page=1" class="page-num on" aria-current="page">1</a></li>
            <li><a href="?page=2" class="page-num">2</a></li>
            <li><a href="?page=3" class="page-num">3</a></li>
            <li><a href="?page=4" class="page-num">4</a></li>
            <li class="page-ellipsis" aria-hidden="true">…</li>
            <li><a href="?page=10" class="page-num">10</a></li>
          </ol>

          <a href="?page=2" class="page-next">
            <span>Next</span><span>→</span>
          </a>
        </div>

        <div class="page-meta">
          <span>Showing <strong>1–24</strong> of 230 items</span>
          <span class="sep">·</span>
          <span class="per-page">
            <span>Per page</span>
            <span class="per-page-chips" id="perPageChips">
              <button class="per-page-chip on" data-size="24">24</button>
              <button class="per-page-chip" data-size="48">48</button>
              <button class="per-page-chip" data-size="96">96</button>
            </span>
          </span>
        </div>

      </nav>

    </div>
  </section>

  <!-- ============================ EXPLAINER ============================ -->
  <section class="explainer">
    <div class="wrap explainer-inner">

      <div class="explainer-head">
        <span class="kicker">How to use this index</span>
        <div class="title">Three ways to <em>narrow</em> the field.</div>
      </div>

      <div class="explainer-body">

        <div class="explainer-card">
          <div class="num">i.</div>
          <h3>Filter by material.</h3>
          <p>Asphalt is the cheapest and most common. Metal lasts longest. Tile is the Florida and Mediterranean staple. Use the filter strip above to narrow to the material your contractor is quoting.</p>
        </div>

        <div class="explainer-card">
          <div class="num">ii.</div>
          <h3>Sort by what matters.</h3>
          <p>Popularity ranks by national install volume. We can also sort by Florida adoption, by lowest cost per square, or by impact rating if your insurance is asking.</p>
        </div>

        <div class="explainer-card">
          <div class="num">iii.</div>
          <h3>Click into a color hub.</h3>
          <p>Each color page has 50+ install examples broken out by house style, the siding colors that pair best, and every shingle SKU available in that color across the seven brands we cover.</p>
        </div>

        <div class="explainer-card">
          <div class="num">iv.</div>
          <h3>Try on your house.</h3>
          <p>From any color hub, open the visualizer with that color pre-filtered. Upload a phone photo and cycle through every SKU in seconds. No signup. Free.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================ CLOSING CTA ============================ -->
  <section class="closing">
    <div class="wrap">
      <span class="kicker">Free · No signup · See it in seconds</span>
      <h2>Or just <em>open</em> the visualizer.</h2>
      <button class="btn-primary" onclick="openVisualizer()">Open the visualizer <span class="arrow">→</span></button>
    </div>
  </section>

  <!-- ============================ FOOTER ============================ -->`;
const inlineScripts = `
  // -------- Filter chip toggle (visual only) --------
  (function () {
    document.querySelectorAll('.filter-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('on'));
        chip.classList.add('on');
      });
    });
  })();

  // -------- Per-page chip toggle (visual only) --------
  // In production, switching per-page would reload the grid with the new
  // page size (e.g. via URL param ?per=48). Stubbed here as a visual demo.
  (function () {
    const chips = document.getElementById('perPageChips');
    if (!chips) return;
    chips.addEventListener('click', (e) => {
      const chip = e.target.closest('.per-page-chip');
      if (!chip) return;
      chips.querySelectorAll('.per-page-chip').forEach(c => c.classList.remove('on'));
      chip.classList.add('on');
      console.log('Per-page changed to:', chip.dataset.size);
    });
  })();

  // -------- Visualizer launcher stub (D1 modal pattern) --------
  function openVisualizer() {
    console.log('Open visualizer (hub)');
    alert('RoofKit visualizer opens here. No SKU pre-selected from the hub index.');
  }
`;
