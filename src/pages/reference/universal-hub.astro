// AUTO-GENERATED by scripts/port-universal-hub.mjs. Re-run: npm run port-universal-hub

import BaseLayout from '@layouts/BaseLayout.astro';

const css = `
  /* -----------------------------------------------------------
     RoofPicker — Universal Hub
     One template, four variants:
       1. Master Color Index   (/roof-colors/)              ← example shown
       2. Comparison Hub        (/compare/)
       3. Brand Hub             (/shingles/[brand]/)
       4. Line Hub              (/shingles/[brand]/[line]/)
     The skeleton (hero + intro + filter strip + grid of cards)
     is identical. Only the card markup changes between variants.
     ----------------------------------------------------------- */

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    font-family: "Geist", system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
    font-weight: 400;
    color: #1A2236;
    background: #F2ECDE;
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; color: inherit; background: none; border: 0; cursor: pointer; }

  :root {
    --paper:   #F2ECDE;
    --shell:   #FAF6EC;
    --ink:     #1A2236;
    --ink-soft:#4A536A;
    --clay:    #B85A3C;
    --clay-deep:#9A4830;
    --sage:    #7B8F6E;
    --rule:    #D9D0BC;
    --hair:    rgba(26, 34, 54, 0.12);
  }

  .wrap { max-width: 1440px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 720px) { .wrap { padding: 0 20px; } }

  .kicker {
    font-family: "Geist Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* ============================================================
     HEADER (same as other templates)
     ============================================================ */
  
  
  
  
  
  
  
  
  
  
  @media (max-width: 760px) {
    .nav-links a:not(.nav-cta) { display: none; }
    .wordmark { font-size: 26px; }
  }

  /* ============================================================
     HUB HERO — Pattern C two-column head + content
     ============================================================ */
  .hub-hero {
    padding: 56px 0 60px;
    border-bottom: 1px solid var(--rule);
  }
  @media (max-width: 720px) { .hub-hero { padding: 32px 0 40px; } }

  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .breadcrumb a:hover { color: var(--clay); }
  .breadcrumb .sep { color: var(--rule); }
  .breadcrumb .current { color: var(--ink); }

  .hub-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: end;
  }
  @media (max-width: 880px) { .hub-head { grid-template-columns: 1fr; gap: 28px; } }

  .hub-head .kicker { display: inline-block; margin-bottom: 18px; }
  .hub-head h1 {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-size: clamp(44px, 6.2vw, 104px);
    line-height: 0.94;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
    max-width: 14ch;
  }
  .hub-head h1 em { font-style: italic; color: var(--clay); }

  .hub-intro p {
    font-family: "Instrument Serif", serif;
    font-size: clamp(18px, 1.7vw, 24px);
    line-height: 1.4;
    color: var(--ink-soft);
    margin: 0;
    letter-spacing: -0.005em;
    max-width: 44ch;
  }
  .hub-intro p em { font-style: italic; color: var(--clay); }
  .hub-intro .stats {
    margin-top: 28px;
    display: flex; flex-wrap: wrap;
    gap: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
  }
  .hub-intro .stat-num {
    font-family: "Instrument Serif", serif;
    font-size: 36px;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .hub-intro .stat-num em { font-style: italic; color: var(--clay); }
  .hub-intro .stat-lbl {
    margin-top: 6px;
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* ============================================================
     FILTER STRIP (optional, only on busier hubs)
     ============================================================ */
  .filter-strip {
    padding: 24px 0;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    position: sticky;
    top: 65px;
    z-index: 40;
    backdrop-filter: blur(10px);
  }
  .filter-row {
    display: flex; align-items: center; gap: 16px;
    flex-wrap: wrap;
  }
  .filter-label {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-right: 4px;
  }
  .filter-row .chips {
    display: flex; flex-wrap: wrap; gap: 6px;
    flex: 1;
  }
  .filter-chip {
    padding: 8px 14px;
    background: var(--shell);
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-chip:hover { border-color: var(--ink); }
  .filter-chip.on {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .filter-sort {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clay);
    border-bottom: 1px solid var(--clay);
    padding-bottom: 2px;
    margin-left: auto;
  }

  /* ============================================================
     CARDS GRID (variant 1: Master Color Index)
     ============================================================ */
  .hub-grid-section {
    padding: 60px 0 100px;
  }
  @media (max-width: 720px) { .hub-grid-section { padding: 40px 0 60px; } }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  @media (max-width: 1100px) { .hub-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px)  { .hub-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; } }

  /* Color card — Master Color Index variant */
  .color-card {
    background: var(--shell);
    border: 1px solid var(--rule);
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    display: block;
  }
  .color-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 48px -22px rgba(26,34,54,0.32);
  }
  .color-card .swatch {
    aspect-ratio: 5 / 4;
    background: var(--card-color, #2E323C);
    position: relative;
    overflow: hidden;
  }
  .color-card .swatch::after {
    content: "";
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(180deg,
      rgba(0,0,0,0.1) 0 1px, transparent 1px 6px);
    mix-blend-mode: multiply;
    opacity: 0.55;
  }
  .color-card .swatch .badge {
    position: absolute;
    top: 14px; right: 14px;
    background: rgba(26,34,54,0.85);
    backdrop-filter: blur(6px);
    color: var(--paper);
    padding: 6px 10px;
    border-radius: 999px;
    font-family: "Geist Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    z-index: 2;
  }
  .color-card .meta {
    padding: 18px 20px 22px;
  }
  .color-card .meta-top {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 8px;
  }
  .color-card .name {
    font-family: "Instrument Serif", serif;
    font-size: 26px;
    line-height: 1.05;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .color-card .hex {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .color-card .desc {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0 0 16px;
    max-width: 28ch;
  }
  .color-card .footer {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 14px;
    border-top: 1px solid var(--rule);
  }
  .color-card .footer .count {
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .color-card .footer .arrow {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 22px;
    color: var(--clay);
    line-height: 1;
    transition: transform 0.2s;
  }
  .color-card:hover .footer .arrow { transform: translateX(4px); }

  /* ============================================================
     PAGINATION (Optional, conditional)
     Activates only when item count exceeds the page threshold.
     Default: 24 per page. Threshold and chip values are page-level
     decisions (24 / 48 / 96).

       - Master Color Index (13 items):  no pagination
       - Comparison Hub (12 items):       no pagination
       - Brand Hub (7 brands or so):      no pagination
       - Line Hub (5 to 15 SKUs):         no pagination
       - Long-color Line Hub (33 colors): pagination active
       - "All SKUs" view (230 items):     pagination active
     ============================================================ */
  .pagination {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  @media (max-width: 720px) { .pagination { margin-top: 36px; padding-top: 24px; } }

  .pagination .controls {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pagination .page-prev, .pagination .page-next {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 10px 18px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--shell);
  }
  .pagination .page-prev:hover, .pagination .page-next:hover {
    border-color: var(--ink);
    background: var(--paper);
  }
  .pagination .page-prev.disabled, .pagination .page-next.disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .pagination .page-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 4px;
    margin: 0 8px;
    padding: 0;
  }
  .pagination .page-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--ink);
    background: var(--shell);
    border: 1px solid var(--rule);
    border-radius: 8px;
    transition: all 0.2s;
  }
  .pagination .page-num:hover {
    border-color: var(--ink);
    background: var(--paper);
  }
  .pagination .page-num.on {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .pagination .page-num.on:hover {
    background: var(--clay);
    border-color: var(--clay);
  }
  .pagination .page-ellipsis {
    font-family: "Geist Mono", monospace;
    font-size: 14px;
    color: var(--ink-soft);
    padding: 0 6px;
    list-style: none;
  }

  .pagination .page-meta {
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pagination .page-meta strong {
    color: var(--ink);
    font-weight: 500;
  }
  .pagination .page-meta .sep { color: var(--rule); }
  .pagination .per-page {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .pagination .per-page-chips {
    display: flex;
    gap: 4px;
  }
  .pagination .per-page-chip {
    padding: 5px 10px;
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .pagination .per-page-chip:hover { border-color: var(--ink); color: var(--ink); }
  .pagination .per-page-chip.on {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  @media (max-width: 520px) {
    .pagination .page-num { min-width: 36px; height: 36px; font-size: 11px; padding: 0 8px; }
    .pagination .page-prev,
    .pagination .page-next { padding: 8px 14px; font-size: 10px; }
  }

  /* ============================================================
     SUPPORTING SECTION — quick explainer or FAQ (optional)
     ============================================================ */
  .explainer {
    background: var(--ink);
    color: var(--paper);
    padding: 100px 0;
  }
  @media (max-width: 720px) { .explainer { padding: 60px 0; } }
  .explainer-inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 60px;
    align-items: start;
  }
  @media (max-width: 880px) { .explainer-inner { grid-template-columns: 1fr; gap: 28px; } }
  .explainer-head .kicker { color: rgba(242,236,222,0.55); margin-bottom: 14px; display: inline-block; }
  .explainer-head .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(34px, 4.8vw, 60px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin: 0;
  }
  .explainer-head .title em { font-style: italic; color: var(--clay); }

  .explainer-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  @media (max-width: 720px) { .explainer-body { grid-template-columns: 1fr; gap: 18px; } }

  .explainer-card {
    background: rgba(242,236,222,0.06);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(242,236,222,0.18);
    border-radius: 14px;
    padding: 24px 24px 26px;
  }
  .explainer-card .num {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 28px;
    color: var(--clay);
    line-height: 1;
    margin-bottom: 12px;
  }
  .explainer-card h3 {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.15;
    color: var(--paper);
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }
  .explainer-card p {
    margin: 0;
    color: rgba(242,236,222,0.7);
    font-size: 14px;
    line-height: 1.55;
  }

  /* ============================================================
     CLOSING CTA
     ============================================================ */
  .closing {
    padding: 140px 0 100px;
    text-align: center;
  }
  @media (max-width: 720px) { .closing { padding: 80px 0 60px; } }
  .closing .kicker { display: block; margin-bottom: 18px; }
  .closing h2 {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-size: clamp(40px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 36px;
    max-width: 18ch;
    margin-left: auto; margin-right: auto;
  }
  .closing h2 em { font-style: italic; color: var(--clay); }
  .btn-primary {
    background: var(--clay);
    color: var(--paper);
    padding: 16px 26px;
    border-radius: 999px;
    font-family: "Geist", sans-serif;
    font-size: 15px;
    font-weight: 500;
    display: inline-flex; align-items: center; gap: 10px;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--clay-deep); transform: translateY(-1px); }
  .btn-primary .arrow {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 22px;
    transition: transform 0.2s;
  }
  .btn-primary:hover .arrow { transform: translateX(3px); }

  /* ============================================================
     FOOTER
     ============================================================ */
  
  
  
  
  
`;
