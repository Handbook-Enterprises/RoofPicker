---
// Strategy 3 SKU hub. Brand rows use native <details> for inline expand.
// Design: Docs/design.md (Warm Florida Modern).
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { breadcrumbList } from '@lib/schema';
import { imageSrc } from '@lib/cdn';

interface BrandIndex {
  brand_slug: string;
  brand_display: string;
  lines: Map<string, {
    line_slug: string;
    line_display: string;
    line_url: string;
    colors: Array<{
      color_slug: string;
      color_display: string;
      color_url: string;
      swatch_src: string;
      hex: string;
    }>;
  }>;
}

const all = await getCollection('skus');

// Build {brand -> line -> [colors]} index from the SKU collection.
const brandIndex = new Map<string, BrandIndex>();

for (const entry of all) {
  const d = entry.data as Record<string, any>;
  const hero = d.sku_hero;
  if (!hero?.brand_slug || !hero?.line_slug || !hero?.color_slug) continue;

  let brand = brandIndex.get(hero.brand_slug);
  if (!brand) {
    brand = {
      brand_slug: hero.brand_slug,
      brand_display: hero.brand_display,
      lines: new Map(),
    };
    brandIndex.set(hero.brand_slug, brand);
  }

  let line = brand.lines.get(hero.line_slug);
  if (!line) {
    line = {
      line_slug: hero.line_slug,
      line_display: hero.line_display,
      line_url: hero.line_url,
      colors: [],
    };
    brand.lines.set(hero.line_slug, line);
  }

  line.colors.push({
    color_slug: hero.color_slug,
    color_display: hero.color_display,
    color_url: d.url_path,
    swatch_src: imageSrc(d.color_desc?.swatch_image),
    hex: hero.hex ?? '#ccc',
  });
}

// Alphabetical at every level: brand, line, color.
const brands = Array.from(brandIndex.values())
  .sort((a, b) => a.brand_display.localeCompare(b.brand_display))
  .map((brand) => ({
    ...brand,
    lines: Array.from(brand.lines.values())
      .sort((a, b) => a.line_display.localeCompare(b.line_display))
      .map((line) => ({
        ...line,
        colors: line.colors.sort((a, b) => a.color_display.localeCompare(b.color_display)),
      })),
  }));

const totalColors = brands.reduce(
  (n, b) => n + b.lines.reduce((m, l) => m + l.colors.length, 0),
  0,
);
---
<BaseLayout
  title="Shingle brands and colors — RoofPicker"
  description={`Every shingle brand, product line, and color in one place. ${totalColors} colors across ${brands.length} brands. Click any color to see the swatch, specs, and try it on your house.`}
  canonical="/shingles/"
  jsonLd={[breadcrumbList([
    { label: 'Home', url: '/' },
    { label: 'Brands', url: '/shingles/' },
  ])]}
>
  <main class="brand-hub">
    <section class="hub-hero">
      <div class="wrap">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <span class="current">Brands</span>
        </nav>
        <span class="kicker">Every brand · every color · 2026</span>
        <h1>Every roof, every <em>color</em>.</h1>
        <p class="lede">
          {totalColors} shingle colors across {brands.length} brands.
          Click a brand to fan out every color in its catalog. Click a color to see the swatch, install specs, and try it on your house.
        </p>
      </div>
    </section>

    <section class="brand-list-section">
      <div class="wrap">
        {brands.map((brand) => {
          const totalForBrand = brand.lines.reduce((n, l) => n + l.colors.length, 0);
          return (
            <details class="brand-row" id={brand.brand_slug}>
              <summary>
                <h2>{brand.brand_display}</h2>
                <span class="count">
                  {totalForBrand} color{totalForBrand === 1 ? '' : 's'} · {brand.lines.length} line{brand.lines.length === 1 ? '' : 's'}
                </span>
                <span class="chev" aria-hidden="true"></span>
              </summary>

              <div class="brand-body">
                {brand.lines.map((line) => (
                  <div class="line-group">
                    <div class="line-head">
                      <h3>{line.line_display}</h3>
                      <span class="line-count">{line.colors.length} color{line.colors.length === 1 ? '' : 's'}</span>
                    </div>
                    <div class="color-grid">
                      {line.colors.map((c) => (
                        <a class="color-tile" href={c.color_url}>
                          <span
                            class="swatch"
                            style={c.swatch_src ? `background-image:url(${c.swatch_src});` : `background:${c.hex};`}
                          ></span>
                          <span class="color-name">{c.color_display}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </details>
          );
        })}
      </div>
    </section>

    <section class="closing">
      <div class="wrap">
        <span class="kicker">Not sure where to start?</span>
        <h2>Just upload a <em>photo</em> of your house.</h2>
        <a class="btn-primary" href="/">Open the visualizer <span class="arrow">→</span></a>
      </div>
    </section>
  </main>

  <style>
    .brand-hub { padding: 0 0 120px; }

    /* ----- HERO ----- */
    .hub-hero { padding: 80px 0 56px; }
    .hub-hero .wrap, .brand-list-section .wrap, .closing .wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 32px;
    }
    @media (max-width: 720px) {
      .hub-hero .wrap, .brand-list-section .wrap, .closing .wrap { padding: 0 20px; }
    }

    .breadcrumb {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .breadcrumb a:hover { color: var(--clay); }
    .breadcrumb .sep { opacity: 0.4; }
    .breadcrumb .current { color: var(--ink); }

    .kicker {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
      display: block;
      margin-bottom: 20px;
    }

    .hub-hero h1 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: clamp(48px, 8vw, 108px);
      line-height: 1.0;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin: 0 0 24px;
    }
    .hub-hero h1 em { font-style: italic; color: var(--clay); }

    .hub-hero .lede {
      font-family: "Geist", system-ui, sans-serif;
      font-size: 18px;
      line-height: 1.55;
      color: var(--ink-soft);
      max-width: 60ch;
      margin: 0;
    }

    /* ----- BRAND ROWS ----- */
    .brand-list-section { padding: 40px 0 60px; }

    .brand-row {
      background: var(--shell);
      border: 1px solid var(--rule);
      border-radius: 18px;
      margin-bottom: 16px;
      overflow: hidden;
      transition: border-color 200ms cubic-bezier(.4,0,.2,1);
    }
    .brand-row:hover { border-color: var(--clay); }
    .brand-row[open] { border-color: var(--clay); }

    .brand-row summary {
      list-style: none;
      cursor: pointer;
      padding: 28px 32px;
      display: flex;
      align-items: center;
      gap: 24px;
      user-select: none;
    }
    .brand-row summary::-webkit-details-marker { display: none; }
    .brand-row summary::marker { display: none; }

    .brand-row summary h2 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: clamp(32px, 4vw, 48px);
      line-height: 1.0;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin: 0;
      flex: 1;
    }

    .brand-row .count {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }

    .brand-row .chev {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--paper);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: transform 200ms cubic-bezier(.4,0,.2,1),
                  background 200ms cubic-bezier(.4,0,.2,1);
      flex-shrink: 0;
    }
    .brand-row .chev::after {
      content: '';
      width: 8px; height: 8px;
      border-right: 1.5px solid var(--ink);
      border-bottom: 1.5px solid var(--ink);
      transform: rotate(45deg) translate(-1px, -1px);
    }
    .brand-row[open] .chev {
      background: var(--clay);
      transform: rotate(180deg);
    }
    .brand-row[open] .chev::after { border-color: var(--paper); }

    /* ----- LINE GROUPS ----- */
    .brand-body { padding: 0 32px 32px; }

    .line-group { margin-top: 32px; }
    .line-group:first-child { margin-top: 8px; }

    .line-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 20px;
    }
    .line-head h3 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: 24px;
      letter-spacing: -0.01em;
      color: var(--ink);
      margin: 0;
    }
    .line-head .line-count {
      font-family: "Geist Mono", ui-monospace, monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }

    /* ----- COLOR TILES ----- */
    .color-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 12px;
    }

    .color-tile {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 6px;
      border-radius: 12px;
      transition: background 150ms cubic-bezier(.4,0,.2,1);
      color: var(--ink);
    }
    .color-tile:hover { background: var(--paper); }

    .color-tile .swatch {
      display: block;
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 10px;
      background-size: cover;
      background-position: center;
      box-shadow: inset 0 0 0 1px var(--hair);
    }

    .color-tile .color-name {
      font-family: "Geist", system-ui, sans-serif;
      font-size: 13px;
      line-height: 1.3;
      color: var(--ink);
      padding: 0 4px 4px;
    }

    /* ----- CLOSING ----- */
    .closing { padding: 80px 0 0; text-align: center; }
    .closing h2 {
      font-family: "Instrument Serif", Georgia, serif;
      font-weight: 400;
      font-size: clamp(36px, 5.4vw, 80px);
      line-height: 1.0;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin: 0 0 32px;
    }
    .closing h2 em { font-style: italic; color: var(--clay); }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--clay);
      color: var(--paper);
      padding: 16px 26px;
      border-radius: 999px;
      font-family: "Geist", system-ui, sans-serif;
      font-size: 15px;
      font-weight: 500;
      transition: background 150ms cubic-bezier(.4,0,.2,1),
                  transform 150ms cubic-bezier(.4,0,.2,1);
    }
    .btn-primary:hover {
      background: var(--clay-deep);
      transform: translateY(-1px);
    }
    .btn-primary .arrow { transition: transform 150ms cubic-bezier(.4,0,.2,1); }
    .btn-primary:hover .arrow { transform: translateX(3px); }
  </style>
</BaseLayout>
