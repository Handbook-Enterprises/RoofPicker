const inlineScripts = `
  // -------- Video background — custom RAF fade system --------
  (function () {
    const video = document.getElementById('heroVideo');
    if (!video) return;

    const FADE_MS = 250;
    const FADE_OUT_REMAINING = 0.55;
    let rafId = null;
    let fadingOutRef = false;

    function cancelFade() {
      if (rafId !== null) { cancelAnimationFrame(rafId); rafId = null; }
    }

    function fadeTo(target, duration) {
      cancelFade();
      const startOpacity = parseFloat(video.style.opacity) || 0;
      const start = performance.now();
      function step(now) {
        const t = Math.min(1, (now - start) / duration);
        video.style.opacity = (startOpacity + (target - startOpacity) * t).toFixed(3);
        if (t < 1) { rafId = requestAnimationFrame(step); } else { rafId = null; }
      }
      rafId = requestAnimationFrame(step);
    }

    function fadeIn()  { fadingOutRef = false; fadeTo(1, FADE_MS); }
    function fadeOut() { fadingOutRef = true;  fadeTo(0, FADE_MS); }

    video.addEventListener('loadeddata', fadeIn);
    video.addEventListener('play',       fadeIn);

    video.addEventListener('timeupdate', () => {
      if (fadingOutRef) return;
      const remaining = video.duration - video.currentTime;
      if (isFinite(remaining) && remaining <= FADE_OUT_REMAINING) fadeOut();
    });

    video.addEventListener('ended', () => {
      video.style.opacity = '0';
      cancelFade();
      setTimeout(() => {
        video.currentTime = 0;
        const p = video.play();
        if (p && p.catch) p.catch(()=>{});
        fadingOutRef = false;
        fadeIn();
      }, 100);
    });

    // Kick playback (some browsers need a nudge)
    const tryPlay = () => { const p = video.play(); if (p && p.catch) p.catch(()=>{}); };
    if (video.readyState >= 2) { tryPlay(); fadeIn(); } else { video.addEventListener('canplay', tryPlay, { once: true }); }
  })();

  // -------- Upload orb → reveal visualizer --------
  (function () {
    const fileInput = document.getElementById('fileInput');
    const orb       = document.getElementById('uploadOrb');
    const fileName  = document.getElementById('fileName');
    const fileSub   = document.getElementById('fileSub');
    const fileThumb = document.getElementById('fileThumb');
    const submitBtn = document.getElementById('uploadSubmit');
    const reveal    = document.getElementById('visualizerReveal');

    fileInput.addEventListener('change', (e) => {
      const f = e.target.files && e.target.files[0];
      if (!f) return;
      orb.classList.add('has-file');
      fileName.textContent = f.name;
      fileSub.textContent = \`\${(f.size/1024/1024).toFixed(2)} MB · click visualize\`;
      const reader = new FileReader();
      reader.onload = ev => { fileThumb.style.backgroundImage = \`url(\${ev.target.result})\`; };
      reader.readAsDataURL(f);
      submitBtn.disabled = false;
    });

    submitBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (submitBtn.disabled) return;
      fileSub.textContent = 'Analyzing roof…';
      submitBtn.disabled = true;
      setTimeout(() => {
        reveal.classList.add('open');
        fileSub.textContent = 'Visualizer ready below ↓';
        const target = document.getElementById('visualizer');
        const y = target.getBoundingClientRect().top + window.pageYOffset - 20;
        window.scrollTo({ top: y, behavior: 'smooth' });
        submitBtn.disabled = false;
      }, 900);
    });
  })();

  // -------- Visualizer interactivity --------
  (function () {
    const vz = document.getElementById('vz');
    const swatchRow = document.getElementById('swatchRow');
    const brandRow = document.getElementById('brandRow');
    const skuName = document.getElementById('skuName');
    const stage = vz.querySelector('.vz-stage');
    const toggleBtns = vz.querySelectorAll('.vz-toggle button');

    const skuMap = {
      'GAF':           'Timberline HDZ',
      'Owens Corning': 'Duration Premium',
      'CertainTeed':   'Landmark Pro',
      'IKO':           'Cambridge',
      'Malarkey':      'Vista AR',
      'Atlas':         'Pinnacle Pristine',
      'TAMKO':         'Heritage',
    };

    let currentBrand = 'GAF';
    let currentColor = 'Driftwood';

    function updateSku() {
      skuName.textContent = \`\${skuMap[currentBrand]} — \${currentColor}\`;
    }

    swatchRow.addEventListener('click', (e) => {
      const sw = e.target.closest('.swatch');
      if (!sw) return;
      swatchRow.querySelectorAll('.swatch').forEach(s => s.classList.remove('on'));
      sw.classList.add('on');
      const color = sw.dataset.color;
      currentColor = sw.dataset.name;
      stage.style.setProperty('--roof', color);
      updateSku();
    });

    brandRow.addEventListener('click', (e) => {
      const chip = e.target.closest('.brand-chip');
      if (!chip) return;
      brandRow.querySelectorAll('.brand-chip').forEach(c => c.classList.remove('on'));
      chip.classList.add('on');
      currentBrand = chip.textContent.trim();
      updateSku();
    });

    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        toggleBtns.forEach(b => b.classList.remove('on'));
        btn.classList.add('on');
        const view = btn.dataset.view;
        vz.classList.remove('show-mask');
        const roofMain = stage.querySelector('.roof-main');
        const roofSide = stage.querySelector('.roof-side');
        if (view === 'before') {
          roofMain.style.background = '#5C5147';
          roofSide.style.background = '#5C5147';
          roofMain.style.filter = 'brightness(0.7) saturate(0.5)';
          roofSide.style.filter = 'brightness(0.65) saturate(0.5)';
        } else if (view === 'mask') {
          vz.classList.add('show-mask');
          roofMain.style.filter = '';
          roofSide.style.filter = '';
        } else {
          roofMain.style.background = '';
          roofSide.style.background = '';
          roofMain.style.filter = '';
          roofSide.style.filter = '';
        }
      });
    });
  })();

  // -------- Mini swap preview in step iii --------
  (function () {
    const roof = document.getElementById('swapRoofMini');
    const swatches = document.getElementById('swapSwatchesMini');
    if (!roof || !swatches) return;
    let i = 0;
    const colors = Array.from(swatches.children).map(c => c.dataset.c);
    // auto-cycle for visual life
    setInterval(() => {
      i = (i + 1) % colors.length;
      roof.style.setProperty('--swap-color', colors[i]);
    }, 2200);
    swatches.addEventListener('click', (e) => {
      const d = e.target.closest('div[data-c]');
      if (!d) return;
      roof.style.setProperty('--swap-color', d.dataset.c);
    });
  })();

  // -------- FAQ accordion --------
  (function () {
    const list = document.getElementById('faqList');
    list.addEventListener('click', (e) => {
      const btn = e.target.closest('.qa-q');
      if (!btn) return;
      const qa = btn.parentElement;
      const open = qa.classList.contains('open');
      // close all
      list.querySelectorAll('.qa').forEach(x => x.classList.remove('open'));
      if (!open) qa.classList.add('open');
    });
  })();

  // -------- How-it-works demo: click-to-play with custom button --------
  (function () {
    const frame = document.querySelector('.how-demo-frame');
    const video = document.getElementById('howDemoVideo');
    const btn   = document.getElementById('howDemoPlay');
    if (!frame || !video || !btn) return;

    btn.addEventListener('click', () => {
      const p = video.play();
      if (p && typeof p.catch === 'function') p.catch(() => {});
    });
    video.addEventListener('click', () => {
      if (video.paused || video.ended) video.play(); else video.pause();
    });
    video.addEventListener('play',  () => frame.classList.add('is-playing'));
    video.addEventListener('pause', () => frame.classList.remove('is-playing'));
    video.addEventListener('ended', () => {
      frame.classList.remove('is-playing');
      try { video.currentTime = 0; } catch(_) {}
    });
  })();

  // -------- Mosaic before/after drag (simple) --------
  (function () {
    document.querySelectorAll('.tile').forEach(tile => {
      const after = tile.querySelector('.after');
      const divider = tile.querySelector('.divider');
      const chip = tile.querySelector('.split-chip');
      let dragging = false;

      function setSplit(x) {
        const r = tile.getBoundingClientRect();
        const pct = Math.max(0, Math.min(100, ((x - r.left) / r.width) * 100));
        after.style.clipPath = \`polygon(\${pct}% 0, 100% 0, 100% 100%, \${pct}% 100%)\`;
        divider.style.left = pct + '%';
        if (chip) chip.style.left = pct + '%';
      }

      const start = (e) => { dragging = true; const x = e.touches ? e.touches[0].clientX : e.clientX; setSplit(x); };
      const move  = (e) => { if (!dragging) return; const x = e.touches ? e.touches[0].clientX : e.clientX; setSplit(x); };
      const end   = () => { dragging = false; };

      tile.addEventListener('mousedown', start);
      window.addEventListener('mousemove', move);
      window.addEventListener('mouseup', end);
      tile.addEventListener('touchstart', start, {passive: true});
      window.addEventListener('touchmove', move, {passive: true});
      window.addEventListener('touchend', end);
    });
  })();
`;

const homepageFaqs = [
  { q: 'Is the visualizer free?', a: 'Yes. No signup required.' },
  { q: 'Does it work on phones?', a: 'Yes. Phone photos are the primary input.' },
