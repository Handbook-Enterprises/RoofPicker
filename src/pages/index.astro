---
// AUTO-GENERATED by scripts/port-homepage.mjs. Re-run: npm run port-homepage

import BaseLayout from '@layouts/BaseLayout.astro';
import { softwareApplication, faqPage } from '@lib/schema';

const css = `
  /* -----------------------------------------------------------
     RoofPicker — Warm Florida modern
     Palette
       --paper      #F2ECDE  warm sand cream (body bg)
       --shell      #FAF6EC  lighter sand for cards/raised
       --ink        #1A2236  deep Atlantic navy (text)
       --ink-soft   #4A536A  muted navy for secondary text
       --clay       #B85A3C  terracotta accent
       --sage       #7B8F6E  sage green secondary
       --rule       #D9D0BC  hairline divider on paper
     Type
       Instrument Serif — display (incl. italic)
       Geist          — body sans
       Geist Mono     — labels, metadata, kickers
     ----------------------------------------------------------- */

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    font-family: "Geist", system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
    font-weight: 400;
    color: #1A2236;
    background: #F2ECDE;
    line-height: 1.45;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; color: inherit; background: none; border: 0; cursor: pointer; }

  :root {
    --paper:   #F2ECDE;
    --shell:   #FAF6EC;
    --ink:     #1A2236;
    --ink-soft:#4A536A;
    --clay:    #B85A3C;
    --clay-deep:#9A4830;
    --sage:    #7B8F6E;
    --rule:    #D9D0BC;
    --hair:    rgba(26, 34, 54, 0.12);
  }

  .wrap { max-width: 1440px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 720px) { .wrap { padding: 0 20px; } }

  .mono { font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace; font-feature-settings: "tnum" 1; }
  .serif { font-family: "Instrument Serif", "Times New Roman", serif; font-weight: 400; }
  .kicker {
    font-family: "Geist Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* ============================================================
     HEADER
     ============================================================ */
  
  
  
  
  
  
  
  
  
  
  @media (max-width: 760px) {
    .nav-links a:not(.nav-cta) { display: none; }
    .wordmark { font-size: 26px; }
  }

  /* ============================================================
     HERO / VISUALIZER
     ============================================================ */
  .hero {
    padding: 36px 0 56px;
    position: relative;
  }
  @media (max-width: 720px) { .hero { padding: 24px 0 40px; } }

  .hero-meta {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 18px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero-meta .left { display: flex; gap: 18px; align-items: baseline; }
  .badge-free {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px 6px 8px;
    border: 1px solid var(--ink);
    border-radius: 999px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--shell);
  }
  .badge-free::before {
    content: "";
    width: 8px; height: 8px;
    background: var(--sage);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(123,143,110,0.25);
  }

  /* Editorial headline */
  .hero h1 {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-size: clamp(48px, 8.8vw, 132px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--ink);
  }
  .hero h1 em {
    font-style: italic;
    color: var(--clay);
  }
  .hero h1 .small {
    font-style: normal;
    font-size: 0.42em;
    color: var(--ink-soft);
    letter-spacing: -0.01em;
    vertical-align: 0.45em;
    display: inline-block;
    margin-left: 0.3em;
  }

  /* Visualizer module */
  .vz {
    background: linear-gradient(180deg, rgba(26,34,54,0.94) 0%, rgba(26,34,54,0.88) 100%);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: var(--paper);
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(242,236,222,0.10);
    box-shadow: 0 30px 60px -30px rgba(26,34,54,0.45),
                inset 0 1px 0 rgba(242,236,222,0.14),
                inset 0 0 0 1px rgba(242,236,222,0.04);
  }
  .vz-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 18px 22px;
    border-bottom: 1px solid rgba(242,236,222,0.12);
  }
  .vz-head .label {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(242,236,222,0.65);
    display: flex; align-items: center; gap: 10px;
  }
  .vz-head .label::before {
    content: "";
    width: 6px; height: 6px;
    background: var(--clay);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100% {opacity:1;} 50% {opacity:0.35;} }
  .vz-toggle {
    display: inline-flex;
    background: rgba(242,236,222,0.1);
    border-radius: 999px;
    padding: 3px;
    gap: 2px;
  }
  .vz-toggle button {
    padding: 6px 14px;
    border-radius: 999px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242,236,222,0.7);
    transition: all 0.2s;
  }
  .vz-toggle button.on {
    background: var(--paper);
    color: var(--ink);
  }

  .vz-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    background:
      linear-gradient(180deg, #6B7A8F 0%, #8DA3B5 60%, #B4C2CC 100%);
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .vz-stage { aspect-ratio: 4 / 3.4; }
  }

  /* Sky elements — minimal */
  .vz-sun {
    position: absolute;
    top: 14%; right: 12%;
    width: 90px; height: 90px;
    background: radial-gradient(circle, rgba(255,224,180,0.7), rgba(255,224,180,0) 70%);
    border-radius: 50%;
  }

  /* Stylized house — composed of simple geometric blocks only */
  .house {
    position: absolute;
    left: 50%; bottom: 0;
    transform: translateX(-50%);
    width: min(78%, 920px);
    height: 78%;
  }
  /* ground */
  .ground {
    position: absolute; left: -20%; right: -20%; bottom: 0;
    height: 18%;
    background: linear-gradient(180deg, #9AA284 0%, #7A8769 100%);
  }
  .ground::after {
    content: "";
    position: absolute; left: 0; right: 0; top: 0; height: 1px;
    background: rgba(26,34,54,0.2);
  }
  /* main body */
  .body-main {
    position: absolute;
    left: 8%; right: 8%; bottom: 12%;
    height: 48%;
    background: #EFE4D0;
    border: 1px solid rgba(26,34,54,0.18);
    border-bottom: 0;
  }
  /* second story setback */
  .body-side {
    position: absolute;
    right: 6%; bottom: 12%;
    width: 22%;
    height: 42%;
    background: #E5D8C0;
    border: 1px solid rgba(26,34,54,0.16);
    border-bottom: 0;
  }
  /* roof — main (trapezoid via clip-path; counts as simple geometry) */
  .roof-main {
    position: absolute;
    left: 5%; right: 5%;
    bottom: 60%;
    height: 24%;
    background: var(--roof, #4A4036);
    clip-path: polygon(8% 100%, 0 100%, 18% 0, 82% 0, 100% 100%, 92% 100%);
    transition: background 0.5s cubic-bezier(.2,.7,.2,1), filter 0.5s;
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.15);
  }
  /* roof — second (smaller pitched roof over setback) */
  .roof-side {
    position: absolute;
    right: 4%;
    bottom: 54%;
    width: 26%;
    height: 18%;
    background: var(--roof, #4A4036);
    clip-path: polygon(0 100%, 18% 0, 82% 0, 100% 100%);
    transition: background 0.5s cubic-bezier(.2,.7,.2,1);
    filter: brightness(0.92);
  }
  /* roof texture lines (very subtle shingle hint) */
  .roof-main::after, .roof-side::after {
    content: "";
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      180deg,
      rgba(0,0,0,0.08) 0 1px,
      transparent 1px 8px
    );
    mix-blend-mode: multiply;
    opacity: 0.7;
    pointer-events: none;
  }
  /* mask outline overlay — "AI-detected roof" */
  .roof-mask {
    position: absolute;
    left: 5%; right: 5%;
    bottom: 60%;
    height: 24%;
    clip-path: polygon(8% 100%, 0 100%, 18% 0, 82% 0, 100% 100%, 92% 100%);
    border: 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(45deg,
        rgba(184,90,60,0.0) 0 8px,
        rgba(184,90,60,0.0) 8px 16px);
    transition: background 0.3s;
  }
  .vz.show-mask .roof-mask {
    background:
      repeating-linear-gradient(45deg,
        rgba(184,90,60,0.35) 0 6px,
        rgba(184,90,60,0) 6px 12px);
    outline: 1.5px dashed var(--clay);
    outline-offset: -3px;
  }
  .vz.show-mask .roof-main { filter: brightness(1.08) saturate(1.1); }

  /* windows */
  .window {
    position: absolute;
    background: linear-gradient(160deg, #C9D4DF 0%, #9DAEBD 100%);
    border: 1px solid rgba(26,34,54,0.4);
  }
  .w1 { left: 16%; bottom: 24%; width: 9%; height: 14%; }
  .w2 { left: 30%; bottom: 24%; width: 9%; height: 14%; }
  .w3 { left: 48%; bottom: 24%; width: 9%; height: 14%; }
  .w4 { right: 22%; bottom: 26%; width: 7%; height: 10%; }
  .w5 { right: 9%; bottom: 26%; width: 7%; height: 10%; }
  /* door */
  .door {
    position: absolute;
    left: 38%; bottom: 12%;
    width: 8%; height: 16%;
    background: #4A3A2C;
    border: 1px solid rgba(0,0,0,0.3);
  }
  /* chimney */
  .chimney {
    position: absolute;
    left: 26%; bottom: 72%;
    width: 5%; height: 14%;
    background: #C9B58E;
    border: 1px solid rgba(26,34,54,0.25);
    z-index: 2;
  }
  /* gutter line */
  .gutter {
    position: absolute;
    left: 5%; right: 5%;
    bottom: 60%;
    height: 4px;
    background: linear-gradient(180deg, rgba(26,34,54,0.35), rgba(26,34,54,0.05));
  }

  /* HUD label on the visualizer */
  .vz-hud {
    position: absolute;
    top: 16px; left: 16px;
    background: rgba(26,34,54,0.7);
    backdrop-filter: blur(6px);
    color: var(--paper);
    padding: 6px 10px;
    border-radius: 6px;
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: flex; align-items: center; gap: 8px;
  }
  .vz-hud::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--clay);
  }

  /* Controls beneath the stage */
  .vz-controls {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 0;
    border-top: 1px solid rgba(242,236,222,0.12);
    background: #131A2A;
  }
  @media (max-width: 760px) {
    .vz-controls { grid-template-columns: 1fr; }
  }
  .vz-brand {
    padding: 22px 24px;
    border-right: 1px solid rgba(242,236,222,0.1);
  }
  @media (max-width: 760px) { .vz-brand { border-right: 0; border-bottom: 1px solid rgba(242,236,222,0.1); } }
  .vz-brand .label, .vz-shingles .label {
    font-family: "Geist Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(242,236,222,0.55);
    margin-bottom: 14px;
  }
  .brand-row {
    display: flex; flex-wrap: wrap;
    gap: 6px;
  }
  .brand-chip {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(242,236,222,0.78);
    padding: 7px 11px;
    border: 1px solid rgba(242,236,222,0.20);
    background: rgba(242,236,222,0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    transition: all 0.2s;
  }
  .brand-chip:hover { color: var(--paper); border-color: rgba(242,236,222,0.45); background: rgba(242,236,222,0.12); }
  .brand-chip.on {
    background: var(--paper);
    color: var(--ink);
    border-color: var(--paper);
  }
  .vz-shingles {
    padding: 22px 24px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .swatch-row {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 10px;
  }
  @media (max-width: 720px) {
    .swatch-row { grid-template-columns: repeat(4, 1fr); gap: 8px; }
  }
  .swatch {
    aspect-ratio: 1;
    border-radius: 6px;
    cursor: pointer;
    position: relative;
    transition: transform 0.15s, box-shadow 0.15s;
    border: 2px solid transparent;
    background-image:
      repeating-linear-gradient(180deg,
        rgba(0,0,0,0.18) 0 1px,
        transparent 1px 5px);
  }
  .swatch:hover { transform: translateY(-2px); }
  .swatch.on {
    border-color: var(--paper);
    box-shadow: 0 0 0 3px rgba(184,90,60,0.5);
  }
  .swatch::after {
    content: attr(data-name);
    position: absolute;
    bottom: -18px; left: 0; right: 0;
    font-family: "Geist Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.04em;
    color: rgba(242,236,222,0.6);
    text-align: center;
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .swatch:hover::after, .swatch.on::after { opacity: 1; }

  .vz-selection {
    display: flex; justify-content: space-between; align-items: baseline;
    padding-top: 4px;
    border-top: 1px dashed rgba(242,236,222,0.12);
  }
  .vz-selection .sku {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 22px;
    color: var(--paper);
  }
  .vz-selection .price {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: rgba(242,236,222,0.55);
    text-transform: uppercase;
  }

  .hero-cta-row {
    display: flex; gap: 14px;
    margin-top: 22px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--clay);
    color: var(--paper);
    padding: 16px 26px;
    border-radius: 999px;
    font-family: "Geist", sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: background 0.2s, transform 0.15s;
    display: inline-flex; align-items: center; gap: 10px;
  }
  .btn-primary:hover { background: var(--clay-deep); transform: translateY(-1px); }
  .btn-primary .arrow { font-family: "Instrument Serif", serif; font-style: italic; font-size: 22px; line-height: 1; transition: transform 0.2s; }
  .btn-primary:hover .arrow { transform: translateX(3px); }
  .btn-ghost {
    color: var(--ink);
    padding: 16px 0;
    font-family: "Geist Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--ink);
  }

  /* ============================================================
     CAPABILITY CALLOUTS — editorial statements, not cards
     ============================================================ */
  .caps {
    padding: 100px 0 80px;
    border-top: 1px solid var(--rule);
    margin-top: 60px;
  }
  @media (max-width: 720px) { .caps { padding: 60px 0 40px; margin-top: 36px; } }

  .caps-head {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 40px;
    margin-bottom: 64px;
    align-items: baseline;
  }
  @media (max-width: 760px) { .caps-head { grid-template-columns: 1fr; gap: 16px; margin-bottom: 36px; } }
  .caps-head .kicker { padding-top: 8px; }
  .caps-head .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(32px, 4.6vw, 64px);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .caps-head .title em { font-style: italic; color: var(--clay); }

  .caps-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .cap {
    display: grid;
    grid-template-columns: 80px 1fr 1.6fr;
    gap: 40px;
    padding: 36px 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .cap:last-child { border-bottom: 1px solid var(--rule); }
  @media (max-width: 760px) {
    .cap { grid-template-columns: 1fr; gap: 12px; padding: 28px 0; }
  }
  .cap .num {
    font-family: "Instrument Serif", serif;
    font-size: 44px;
    line-height: 1;
    color: var(--clay);
    font-style: italic;
  }
  .cap .head {
    font-family: "Instrument Serif", serif;
    font-size: clamp(24px, 2.4vw, 34px);
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .cap .body {
    font-size: 16px;
    color: var(--ink-soft);
    max-width: 48ch;
    line-height: 1.55;
  }

  /* ============================================================
     BRAND COVERAGE STRIP
     ============================================================ */
  .brands {
    background: var(--ink);
    color: var(--paper);
    padding: 80px 0;
    margin: 0;
    overflow: hidden;
  }
  .brands-inner {
    display: grid;
    grid-template-columns: 1fr 2.2fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 880px) { .brands-inner { grid-template-columns: 1fr; gap: 28px; } }
  .brands .kicker { color: rgba(242,236,222,0.55); margin-bottom: 14px; }
  .brands .lede {
    font-family: "Instrument Serif", serif;
    font-size: clamp(26px, 2.4vw, 36px);
    line-height: 1.15;
    color: var(--paper);
    letter-spacing: -0.01em;
  }
  .brands .lede em { color: var(--clay); font-style: italic; }
  .brand-list {
    font-family: "Instrument Serif", serif;
    font-size: clamp(34px, 5.5vw, 76px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin: 0;
  }
  .brand-list span {
    display: inline-block;
    padding: 0 0.18em;
    white-space: nowrap;
  }
  .brand-list .sep {
    color: var(--clay);
    font-style: italic;
    padding: 0 0.18em;
    white-space: nowrap;
  }
  .brand-foot {
    margin-top: 28px;
    display: flex; justify-content: space-between; align-items: baseline; gap: 24px;
    flex-wrap: wrap;
    border-top: 1px solid rgba(242,236,222,0.15);
    padding-top: 20px;
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(242,236,222,0.55);
  }

  /* ============================================================
     HOW IT WORKS — three large stepped panels
     ============================================================ */
  .how {
    padding: 110px 0 90px;
  }
  @media (max-width: 720px) { .how { padding: 60px 0 40px; } }

  .how-head {
    display: grid; grid-template-columns: 1fr 2fr; gap: 40px;
    margin-bottom: 60px; align-items: baseline;
  }
  @media (max-width: 760px) { .how-head { grid-template-columns: 1fr; gap: 14px; margin-bottom: 36px; } }
  .how-head .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(36px, 5.4vw, 80px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .how-head .title em { font-style: italic; color: var(--clay); }

  /* 30-second demo video block */
  .how-demo {
    margin: 0 0 64px;
  }
  @media (max-width: 720px) { .how-demo { margin-bottom: 40px; } }
  .how-demo-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 18px;
    overflow: hidden;
    background: #0c0d0a;
    border: 1px solid var(--rule);
    box-shadow: 0 30px 80px -40px rgba(0,0,0,0.45);
  }
  .how-demo-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.55) saturate(0.9);
    transition: filter .4s ease;
  }
  .how-demo-frame.is-playing .how-demo-video, .how-demo-frame.is-paused-mid .how-demo-video { filter: none; }
  .how-demo-chrome {
    position: absolute; top: 16px; left: 16px;
    display: inline-flex; align-items: center; gap: 8px;
    white-space: nowrap;
    background: rgba(12,13,10,0.6);
    backdrop-filter: blur(8px);
    color: #f3f3f3;
    font-family: "Fustat", "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .how-demo-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 0 3px rgba(239,68,68,0.25);
    animation: how-demo-pulse 1.6s ease-in-out infinite;
  }
  @keyframes how-demo-pulse { 0%,100%{opacity:1} 50%{opacity:0.45} }

  /* Play overlay — echoes the upload orb: circling text + clay core */
  .how-demo-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 220px; height: 220px;
    background: transparent;
    border: 0;
    cursor: pointer;
    z-index: 6;
    display: grid; place-items: center;
    padding: 0;
    color: #fff;
    transition: opacity .35s ease;
  }
  .how-demo-play-ring {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    animation: how-demo-ring-spin 16s linear infinite;
  }
  .how-demo-play-ring-text {
    font-family: "Fustat", "Inter", sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    fill: #f3f3f3;
  }
  @keyframes how-demo-ring-spin { to { transform: rotate(360deg); } }
  .how-demo-play-core {
    position: relative;
    width: 96px; height: 96px;
    border-radius: 50%;
    background: var(--clay);
    display: grid; place-items: center;
    color: #fff;
    box-shadow:
      0 18px 48px rgba(0,0,0,0.45),
      0 0 0 1px rgba(255,255,255,0.18) inset,
      0 0 0 0 rgba(217,119,87,0.55);
    transition: transform .25s cubic-bezier(.2,.7,.2,1.2), box-shadow .35s ease;
  }
  .how-demo-play-core::before {
    content: "";
    position: absolute; inset: -10px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.18);
    animation: how-demo-halo 2.4s ease-out infinite;
  }
  @keyframes how-demo-halo {
    0%   { transform: scale(0.92); opacity: 0.9; }
    100% { transform: scale(1.35); opacity: 0; }
  }
  .how-demo-play-core svg { width: 30px; height: 30px; margin-left: 4px; }
  .how-demo-play:hover .how-demo-play-core {
    transform: scale(1.06);
    box-shadow:
      0 24px 60px rgba(0,0,0,0.55),
      0 0 0 1px rgba(255,255,255,0.22) inset,
      0 0 0 14px rgba(217,119,87,0.10);
  }
  .how-demo-play:active .how-demo-play-core { transform: scale(0.96); }
  .how-demo-play-tick {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    background: #0e1311;
    color: #f3f3f3;
    font-family: "Fustat", "Inter", sans-serif;
    font-feature-settings: "tnum" 1;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 5px 9px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.14);
  }
  .how-demo-frame.is-playing .how-demo-play {
    opacity: 0; pointer-events: none;
  }
  @media (max-width: 720px) {
    .how-demo-play { width: 160px; height: 160px; }
    .how-demo-play-core { width: 76px; height: 76px; }
    .how-demo-play-core svg { width: 24px; height: 24px; }
    .how-demo-play-ring-text { font-size: 9.5px; letter-spacing: 0.18em; }
  }

  .how-demo-frame.is-playing .how-demo-beats {
    opacity: 0; pointer-events: none; transition: opacity .35s ease;
  }
  .how-demo-beats {
    position: absolute; left: 0; right: 0; bottom: 0;
    display: flex; align-items: center; justify-content: center;
    gap: 18px;
    padding: 14px 20px;
    background: linear-gradient(to top, rgba(12,13,10,0.85), rgba(12,13,10,0));
    color: #f3f3f3;
    font-family: "Fustat", "Inter", sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .how-demo-beats .beat { display: inline-flex; align-items: baseline; gap: 8px; }
  .how-demo-beats .beat b {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-style: italic;
    font-size: 16px;
    color: var(--clay);
  }
  .how-demo-beats .beat-sep {
    width: 24px; height: 1px; background: rgba(255,255,255,0.25);
  }
  @media (max-width: 720px) {
    .how-demo-beats { gap: 10px; font-size: 11px; padding: 10px 12px; }
    .how-demo-beats .beat b { font-size: 14px; }
    .how-demo-beats .beat-sep { width: 14px; }
  }
  .how-demo-cap {
    margin: 14px 4px 0;
    font-family: "Fustat", "Inter", sans-serif;
    font-size: 13px;
    color: #6b6b6b;
    letter-spacing: -0.01em;
    text-align: center;
  }

  .steps {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
  }
  @media (max-width: 980px) { .steps { grid-template-columns: 1fr; gap: 16px; } }

  .step {
    background: var(--shell);
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 28px 26px 32px;
    display: flex; flex-direction: column;
    min-height: 380px;
    position: relative;
    overflow: hidden;
  }
  .step .num {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 22px;
    color: var(--clay);
  }
  .step .step-title {
    font-family: "Instrument Serif", serif;
    font-size: 32px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 8px 0 12px;
  }
  .step .step-body {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.5;
    max-width: 32ch;
  }
  .step .step-visual {
    margin-top: auto;
    padding-top: 24px;
    height: 180px;
    position: relative;
  }

  /* Step 1 — upload visual */
  .upload-target {
    position: absolute; inset: 0;
    border: 2px dashed var(--rule);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 8px;
    background:
      repeating-linear-gradient(135deg,
        rgba(123,143,110,0.06) 0 8px,
        transparent 8px 16px);
  }
  .upload-target .icon {
    width: 36px; height: 36px;
    border: 1.5px solid var(--ink);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 22px;
    color: var(--ink);
  }
  .upload-target .label {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  /* Step 2 — mask visual */
  .mask-preview {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, #6B7A8F 0%, #9DAEBD 100%);
    border-radius: 10px;
    overflow: hidden;
  }
  .mp-house {
    position: absolute;
    left: 18%; right: 18%; bottom: 6%; top: 38%;
    background: #EFE4D0;
    border: 1px solid rgba(26,34,54,0.18);
    border-bottom: 0;
  }
  .mp-roof {
    position: absolute;
    left: 12%; right: 12%; top: 18%; bottom: 60%;
    background: #4A4036;
    clip-path: polygon(8% 100%, 0 100%, 18% 0, 82% 0, 100% 100%, 92% 100%);
  }
  .mp-mask-overlay {
    position: absolute;
    left: 12%; right: 12%; top: 18%; bottom: 60%;
    clip-path: polygon(8% 100%, 0 100%, 18% 0, 82% 0, 100% 100%, 92% 100%);
    background: repeating-linear-gradient(45deg,
      rgba(184,90,60,0.55) 0 4px,
      rgba(184,90,60,0.15) 4px 10px);
    animation: maskShift 3s linear infinite;
  }
  @keyframes maskShift {
    0% { background-position: 0 0; }
    100% { background-position: 24px 0; }
  }
  .mp-ticks {
    position: absolute; inset: 0;
    pointer-events: none;
  }
  .mp-tick {
    position: absolute;
    width: 14px; height: 14px;
    border: 1.5px solid var(--clay);
    border-radius: 50%;
    background: rgba(184,90,60,0.25);
  }
  .mp-tick.a { top: 26%; left: 22%; }
  .mp-tick.b { top: 22%; left: 60%; }
  .mp-tick.c { top: 18%; left: 78%; }
  /* Step 3 — swap visual */
  .swap-preview {
    position: absolute; inset: 0;
    display: grid;
    grid-template-rows: 1fr auto;
    gap: 10px;
  }
  .swap-roof {
    background: linear-gradient(180deg, #8DA3B5, #B4C2CC);
    border-radius: 8px;
    position: relative;
    overflow: hidden;
  }
  .swap-roof::after {
    content: "";
    position: absolute;
    left: 16%; right: 16%; top: 20%; bottom: 35%;
    background: var(--swap-color, #4A4036);
    clip-path: polygon(8% 100%, 0 100%, 18% 0, 82% 0, 100% 100%, 92% 100%);
    transition: background 0.5s;
  }
  .swap-roof::before {
    content: "";
    position: absolute;
    left: 16%; right: 16%; top: 65%; bottom: 5%;
    background: #EFE4D0;
    border: 1px solid rgba(26,34,54,0.15);
    border-bottom: 0;
  }
  .swap-swatches {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 6px;
  }
  .swap-swatches div {
    aspect-ratio: 1;
    border-radius: 4px;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .swap-swatches div:hover { transform: scale(1.1); }

  /* ============================================================
     GALLERY — magazine mosaic
     ============================================================ */
  .gallery {
    padding: 0 0 100px;
  }
  .gallery-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 36px;
    gap: 24px; flex-wrap: wrap;
  }
  .gallery-head .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .gallery-head .title em { font-style: italic; color: var(--clay); }
  .gallery-head .meta { color: var(--ink-soft); font-size: 15px; max-width: 40ch; }

  .mosaic {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
    grid-auto-rows: 110px;
  }
  @media (max-width: 880px) {
    .mosaic { grid-template-columns: repeat(6, 1fr); grid-auto-rows: 90px; }
  }
  @media (max-width: 520px) {
    .mosaic { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 130px; }
  }
  .tile {
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: var(--shell);
    border: 1px solid var(--rule);
  }
  .tile .before, .tile .after {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    background-size: cover; background-position: center;
    user-select: none;
    -webkit-user-drag: none;
  }
  .tile .after {
    clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%);
  }

  /* Split color chip — straddles divider, half = before roof color, half = after */
  .tile .split-chip {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    width: 54px; height: 54px;
    border-radius: 50%;
    overflow: hidden;
    z-index: 4;
    display: flex;
    border: 3px solid #fff;
    box-shadow: 0 6px 18px rgba(0,0,0,0.35), 0 0 0 1px rgba(0,0,0,0.08);
    pointer-events: none;
  }
  .tile .split-chip > span {
    flex: 1 1 50%;
    height: 100%;
    display: block;
  }
  @media (max-width: 520px) {
    .tile .split-chip { width: 42px; height: 42px; top: 10px; border-width: 2px; }
  }
  .tile .divider {
    position: absolute;
    top: 0; bottom: 0; left: 50%;
    width: 2px;
    background: var(--paper);
    z-index: 2;
  }
  .tile .divider::after {
    content: "";
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--paper);
    border: 2px solid var(--ink);
  }
  .tile .tag {
    position: absolute;
    bottom: 10px; left: 10px;
    background: rgba(26,34,54,0.85);
    color: var(--paper);
    padding: 4px 8px;
    border-radius: 4px;
    font-family: "Geist Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    z-index: 3;
  }
  .tile .ba-marks {
    position: absolute;
    top: 10px; left: 10px; right: 10px;
    display: flex; justify-content: space-between;
    z-index: 3;
    font-family: "Geist Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    color: var(--paper);
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }

  /* Mosaic span variants */
  .tile.s1 { grid-column: span 7; grid-row: span 4; }
  .tile.s2 { grid-column: span 5; grid-row: span 4; }
  .tile.s3 { grid-column: span 5; grid-row: span 3; }
  .tile.s4 { grid-column: span 7; grid-row: span 3; }
  .tile.s5 { grid-column: span 7; grid-row: span 3; }
  .tile.s6 { grid-column: span 5; grid-row: span 3; }
  .tile.s5 { grid-column: span 3; grid-row: span 3; }
  .tile.s6 { grid-column: span 3; grid-row: span 3; }
  .tile.s7 { grid-column: span 4; grid-row: span 3; }
  .tile.s8 { grid-column: span 4; grid-row: span 3; }
  .tile.s9 { grid-column: span 4; grid-row: span 3; }
  .tile.s10 { grid-column: span 8; grid-row: span 3; }
  .tile.s11 { grid-column: span 4; grid-row: span 3; }
  .tile.s12 { grid-column: span 8; grid-row: span 3; }

  @media (max-width: 880px) {
    .tile.s1, .tile.s2, .tile.s3, .tile.s4, .tile.s5, .tile.s6 { grid-column: span 6; grid-row: span 3; }
    .tile.s7, .tile.s8, .tile.s9, .tile.s10, .tile.s11, .tile.s12 { grid-column: span 3; }
  }
  @media (max-width: 520px) {
    .tile { grid-column: span 2 !important; grid-row: span 2 !important; }
  }

  /* tile after-color variants — terracotta, slate, weathered wood, forest, charcoal, etc. */
  .tile.c-clay .after { background: repeating-linear-gradient(180deg, #B85A3C 0 4px, #9A4830 4px 8px); }
  .tile.c-slate .after { background: repeating-linear-gradient(180deg, #4A5060 0 4px, #353A48 4px 8px); }
  .tile.c-driftwood .after { background: repeating-linear-gradient(180deg, #8A7960 0 4px, #6F6049 4px 8px); }
  .tile.c-forest .after { background: repeating-linear-gradient(180deg, #3D4A3C 0 4px, #2A352A 4px 8px); }
  .tile.c-charcoal .after { background: repeating-linear-gradient(180deg, #2E323C 0 4px, #1E2128 4px 8px); }
  .tile.c-sage .after { background: repeating-linear-gradient(180deg, #6B7A5E 0 4px, #525E48 4px 8px); }
  .tile.c-rust .after { background: repeating-linear-gradient(180deg, #8C4A2A 0 4px, #6F3A20 4px 8px); }
  .tile.c-bronze .after { background: repeating-linear-gradient(180deg, #6F5A3C 0 4px, #54442C 4px 8px); }
  .tile.c-storm .after { background: repeating-linear-gradient(180deg, #5C6470 0 4px, #424954 4px 8px); }
  .tile.c-pewter .after { background: repeating-linear-gradient(180deg, #6E7480 0 4px, #545964 4px 8px); }
  .tile.c-coal .after { background: repeating-linear-gradient(180deg, #25282E 0 4px, #15171B 4px 8px); }
  .tile.c-clay-light .after { background: repeating-linear-gradient(180deg, #C97A5A 0 4px, #A85A3D 4px 8px); }

  /* ============================================================
     FAQ
     ============================================================ */
  .faq {
    background: var(--ink);
    color: var(--paper);
    padding: 110px 0 110px;
  }
  @media (max-width: 720px) { .faq { padding: 60px 0 60px; } }
  .faq-inner {
    display: grid; grid-template-columns: 1fr 2fr;
    gap: 60px; align-items: start;
  }
  @media (max-width: 880px) { .faq-inner { grid-template-columns: 1fr; gap: 28px; } }
  .faq-head .kicker { color: rgba(242,236,222,0.55); margin-bottom: 14px; }
  .faq-head .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(40px, 5.8vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  .faq-head .title em { font-style: italic; color: var(--clay); }
  .faq-head .note {
    margin-top: 22px;
    color: rgba(242,236,222,0.7);
    max-width: 28ch;
    line-height: 1.5;
    font-size: 15px;
  }

  .faq-list {
    display: flex; flex-direction: column;
    gap: 10px;
  }
  .qa {
    background: rgba(242,236,222,0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(242,236,222,0.12);
    border-radius: 14px;
    padding: 0 22px;
    transition: background 0.2s, border-color 0.2s;
  }
  .qa:hover { background: rgba(242,236,222,0.08); border-color: rgba(242,236,222,0.18); }
  .qa.open { background: rgba(242,236,222,0.09); border-color: rgba(242,236,222,0.22); }
  .qa-q {
    display: flex; justify-content: space-between; align-items: center;
    width: 100%;
    padding: 24px 0;
    text-align: left;
    font-family: "Instrument Serif", serif;
    font-size: clamp(22px, 2vw, 28px);
    line-height: 1.2;
    color: var(--paper);
    letter-spacing: -0.005em;
  }
  .qa-q .plus {
    width: 28px; height: 28px;
    position: relative;
    flex-shrink: 0;
    margin-left: 24px;
  }
  .qa-q .plus::before, .qa-q .plus::after {
    content: ""; position: absolute;
    background: var(--paper);
    transition: transform 0.25s;
  }
  .qa-q .plus::before {
    top: 50%; left: 0; right: 0; height: 1.5px; transform: translateY(-50%);
  }
  .qa-q .plus::after {
    left: 50%; top: 0; bottom: 0; width: 1.5px; transform: translateX(-50%);
  }
  .qa.open .qa-q .plus::after { transform: translateX(-50%) rotate(90deg); opacity: 0; }
  .qa-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
  }
  .qa.open .qa-a {
    max-height: 400px;
    padding: 0 0 26px;
  }
  .qa-a p {
    margin: 0;
    color: rgba(242,236,222,0.78);
    max-width: 62ch;
    font-size: 16px;
    line-height: 1.6;
  }

  /* ============================================================
     CLOSING CTA
     ============================================================ */
  .closing {
    padding: 140px 0 100px;
    text-align: center;
  }
  @media (max-width: 720px) { .closing { padding: 80px 0 60px; } }
  .closing .kicker { display: block; margin-bottom: 18px; }
  .closing h2 {
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-size: clamp(44px, 8vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 36px;
  }
  .closing h2 em { font-style: italic; color: var(--clay); }

  /* ============================================================
     FOOTER
     ============================================================ */
  
  
  
  
  

  /* ============================================================
     HERO V2 — Video background + upload
     ============================================================ */
  .hero-v2 {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: #0a0a0a;
  }
  .hero-v2 .video-bg {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 115%; height: 115%;
    object-fit: cover;
    object-position: top;
    opacity: 0;
    will-change: opacity;
  }
  .hero-v2 .video-veil {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg,
        rgba(242,236,222,0.55) 0%,
        rgba(242,236,222,0.22) 30%,
        rgba(242,236,222,0.18) 55%,
        rgba(242,236,222,0.62) 72%,
        rgba(242,236,222,0.92) 90%,
        rgba(242,236,222,1) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Nav over hero */
  
  @media (max-width: 1100px) { .nav-v2 { padding: 16px 40px; } }
  @media (max-width: 720px)  { .nav-v2 { padding: 16px 20px; } }
  
  
  
  
  @media (max-width: 980px) { .nav-v2 .menu { display: none; } }
  
  
  
  
  
  
  

  /* Hero centerpiece */
  .hero-v2-content {
    position: relative; z-index: 5;
    display: flex; flex-direction: column; align-items: center;
    padding: 0 120px;
    margin-top: -50px;
    gap: 44px;
    padding-bottom: 80px;
  }
  @media (max-width: 1100px) { .hero-v2-content { padding: 0 40px 60px; } }
  @media (max-width: 720px)  { .hero-v2-content { padding: 0 20px 48px; gap: 32px; margin-top: -20px; } }

  .hero-v2-header {
    display: flex; flex-direction: column; align-items: center;
    gap: 28px;
    padding-top: 40px;
  }
  @media (max-width: 720px) { .hero-v2-header { gap: 24px; padding-top: 20px; } }

  .hero-v2 .badge {
    display: inline-flex; align-items: center;
    background: #fff;
    border-radius: 999px;
    padding: 4px 14px 4px 4px;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #000;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    gap: 10px;
  }
  .hero-v2 .badge .pill {
    display: inline-flex; align-items: center; gap: 5px;
    background: #0e1311;
    color: #fff;
    padding: 4px 10px;
    border-radius: 999px;
    font-weight: 500;
